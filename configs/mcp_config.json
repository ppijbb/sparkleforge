{
  "mcpServers": {
    "local-search": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.search_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}"
      },
      "disabled": false
    },
    "code-executor": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.context_mode_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "SPARKLEFORGE_PROJECT_DIR": "${PROJECT_ROOT}"
      },
      "disabled": true
    },
    "data-analyzer": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.context_mode_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "SPARKLEFORGE_PROJECT_DIR": "${PROJECT_ROOT}"
      },
      "disabled": true
    },
    "web-fetch": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.web_fetch_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}"
      },
      "disabled": false
    },
    "search": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.search_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}"
      },
      "disabled": false
    },
    "arxiv": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.arxiv_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}"
      },
      "disabled": false
    },
    "memory": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.memory_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}",
        "MEMORY_STORAGE_DIR": "${PROJECT_ROOT}/data/memory"
      },
      "disabled": false
    },
    "filesystem": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.filesystem_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}",
        "MCP_FILESYSTEM_ALLOWED_PATHS": "${PROJECT_ROOT},/tmp"
      },
      "disabled": false
    },
    "github": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.github_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabled": false
    },
    "context-mode": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.context_mode_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}",
        "SPARKLEFORGE_PROJECT_DIR": "${PROJECT_ROOT}"
      },
      "disabled": false
    },
    "cli-anything": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.cli_anything_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}"
      },
      "disabled": false
    },
    "sparkleforge-skills": {
      "command": "python",
      "args": [
        "-m",
        "src.core.mcp_servers.skills_provider_server"
      ],
      "env": {
        "PYTHONPATH": "${PROJECT_ROOT}",
        "PYTHONPATH_ADD": "${PROJECT_ROOT}"
      },
      "disabled": false
    },
    "semanticscholar": {
      "type": "stdio",
      "command": "python",
      "args": [
        "/home/user/workspace/mcp_agent/primary/SparkleForge/temp/mcp_servers/semanticscholar/server.py"
      ]
    },
    "semantic_scholar": {
      "type": "stdio",
      "command": "python",
      "args": [
        "/home/user/workspace/mcp_agent/primary/SparkleForge/temp/mcp_servers/semantic_scholar/server.py"
      ]
    },
    "fetch_service": {
      "type": "stdio",
      "command": "python",
      "args": [
        "/home/user/workspace/mcp_agent/primary/SparkleForge/temp/mcp_servers/fetch_service/server.py"
      ]
    },
    "element_extractor": {
      "type": "stdio",
      "command": "python",
      "args": [
        "/home/user/workspace/mcp_agent/primary/SparkleForge/temp/mcp_servers/element_extractor/server.py"
      ]
    },
    "web_fetcher": {
      "type": "stdio",
      "command": "python",
      "args": [
        "/home/user/workspace/mcp_agent/primary/SparkleForge/temp/mcp_servers/web_fetcher/server.py"
      ]
    },
    "duckduckgo_search": {
      "type": "stdio",
      "command": "python",
      "args": [
        "/home/user/workspace/mcp_agent/primary/SparkleForge/temp/mcp_servers/duckduckgo_search/server.py"
      ]
    }
  },
  "_metadata": {
    "description": "MCP servers - 3 local + 6 embedded (context-mode for 95% token reduction)",
    "embedded_servers": [
      "web-fetch",
      "search",
      "arxiv",
      "memory",
      "filesystem",
      "github",
      "context-mode",
      "cli-anything"
    ],
    "local_servers": [
      "local-search",
      "code-executor",
      "data-analyzer"
    ]
  }
}